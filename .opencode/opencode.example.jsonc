{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    ".opencode/rules/context7.md",
    ".opencode/rules/spring-boot-4-api-changes.md"
  ],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "<YOUR_API_KEY>"
      },
      "enabled": true
    }
  }
}
